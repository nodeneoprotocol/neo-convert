# ─────────────────────────────────────────────────────────────
# NeoConvert — Variáveis de Ambiente
# Copie este arquivo: cp .env.example .env.local
# ─────────────────────────────────────────────────────────────

# ── FLOWPAY API (Checkout Pix centralizado na stack NEO) ─────
# Endpoint canônico do backend de pagamentos
FLOWPAY_API_URL=https://api.flowpay.cash
# API key interna do FlowPay (x-api-key para /api/create-charge)
FLOWPAY_INTERNAL_API_KEY=
# Alias legado aceito no neo-convert (fallback)
# FLOWPAY_API_KEY=
#
# Não usar estes segredos para checkout (são para validação de webhook):
# FLOWPAY_SIGNATURE_SECRET=
# FLOWPAY_WEBHOOK_SECRET=

# ── MAILTRAP (Email transacional) ─────────────────────────────
# Obter em: https://mailtrap.io → Email Sending → API Tokens
MAILTRAP_API_TOKEN=

# Remetente (deve estar verificado no Mailtrap para produção)
MAILTRAP_FROM_EMAIL=no-reply@neo-convert.com
MAILTRAP_FROM_NAME=NeoConvert

# ── APP ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Security Secret for Cron Jobs
CRON_SECRET=
